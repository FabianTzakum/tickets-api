// Tickets.Api/appsettings.json

{
  "App": {
    "Name": "Tickets API",
    "Version": "1.0.0"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "http://127.0.0.1:5173",
      "https://127.0.0.1:5173",
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=TicketsApi;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "TicketsApi",
    "Audience": "TicketsApiClient",
    "SecretKey": "CHANGE_THIS_DEVELOPMENT_SECRET_KEY_1234567890",
    "ExpirationMinutes": 120
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}